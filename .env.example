# Пример файла переменных окружения
# Заполните значениями для вашего окружения и сохраните как .env

# База данных MongoDB
MONGODB_URI=mongodb://<user>:<password>@<host>:27017/<db>?replicaSet=<rs>&directConnection=true

# JWT
JWT_SECRET=replace_me_with_strong_random_secret
JWT_EXPIRATION=24h

# Admins (список Telegram ID через запятую)
ADMIN_TELEGRAM_IDS=

# Сервер
PORT=3001
CLIENT_URL=http://localhost:3000

# YooKassa
YOOKASSA_MODE=test
YOOKASSA_SHOP_ID_TEST=
YOOKASSA_SECRET_KEY_TEST=
YOOKASSA_SHOP_ID_PROD=
YOOKASSA_SECRET_KEY_PROD=
YOOKASSA_WEBHOOK_USER=
YOOKASSA_WEBHOOK_PASSWORD=

# Telegram Bot (для проверки initData)
BOT_TOKEN=
REQUIRE_TG_INITDATA=false
TG_INITDATA_MAX_AGE_SEC=120
REDIS_URL=
AB_SPLIT_A=50

# Telegram bot webhook security
TELEGRAM_WEBHOOK_SECRET=

# Bot → Backend REST security
BOT_BACKEND_SECRET=

# Онлайн TTL (мс)
ONLINE_TTL_MS=60000


# «Честный режим»: true — разом отключает фиктивную статистику онлайна и
# ИИ-собеседников (активные ИИ-чаты завершаются при старте). Дефолт: false.
HONEST_MODE=false
# Гранулярные тумблеры фикции (работают, когда HONEST_MODE=false).
# ВАЖНО: FAKE_STATS_ENABLED и AI_COMPANION_ENABLED — только НАЧАЛЬНЫЕ значения
# при первом запуске: дальше они (плюс лимиты поиска и авто-разрыв ИИ-чата)
# управляются рантайм-тумблерами из админки https://anoname.ru/admin/settings.html
# (GET/PUT /api/admin/settings, коллекция globalsettings в Mongo).
FAKE_STATS_ENABLED=true
FAKE_STATS_SCALE=1
AI_COMPANION_ENABLED=true

# Web Push (VAPID): npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# CORS: доп. origin'ы через запятую (например https://localhost для Android-приложения)
CORS_WHITELIST=
